model masterDropdownType {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())

  name        String   @db.VarChar(255)
  key         String   @unique @db.VarChar(255)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  isActive    Boolean  @default(true) @map("is_active")

  categories  masterDropdownCategory[]

  @@map("master_dropdown_types")
}



model masterDropdownCategory {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())

  typeId      String
  type        masterDropdownType @relation(fields: [typeId], references: [id])

  label       String   @db.VarChar(255)
  value       String   @db.VarChar(255)

  sortOrder   Int?     @default(1)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  isActive    Boolean  @default(true) @map("is_active")

  @@unique([typeId, value])

  @@index([typeId])

  @@map("master_dropdown_categories")
}



model inspection_module {
  id String @id @default(uuid())

  name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moduleStages module_stage[]
  progresses inspection_progress[]
}

model inspection_stage {
  id String @id @default(uuid())

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moduleStages module_stage[]
  progresses inspection_progress[]
}

model module_stage {
  id String @id @default(uuid())

  moduleId String
  stageId String

  module inspection_module @relation(fields: [moduleId],references: [id])

  stage inspection_stage @relation(fields: [stageId],references: [id])

  questions inspection_question[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, stageId])
}

model inspection_question {
  id String @id @default(uuid())

  moduleStageId String

  materialId String?
  materialName String?

  type String?
  // BRAND
  // GRADE
  // TYPE
  // OTHER

  question String

  fieldType String

  minLimit Int?
  maxLimit Int?

  isRequired Boolean @default(false)

  conditionalRendering Json?

  sortOrder Int @default(1)

  isActive Boolean @default(true)

  moduleStage module_stage @relation(fields: [moduleStageId], references: [id])

  material material? @relation(fields: [materialId], references: [id])

  options inspection_question_option[]

  answers inspection_answer[]

  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model inspection_question_option {
  id String @id @default(uuid())

  questionId String

  materialId String?

  referenceId String?
  // brand.id
  // grade.id
  // material_type.id

  value String

  sortOrder Int @default(1)

  question inspection_question @relation(fields: [questionId],references: [id])

  material material? @relation(fields: [materialId],references: [id])

  answers inspection_answer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model inspection_progress {
  id String @id @default(uuid())

  projectId String
  moduleId String
  blockId String?
  floorId String?
  roomNo String?
  stageId String

  workStartedDate DateTime?
  isDelay Boolean @default(false)
  delayDays Int?
  delayReason String?
  delayOtherReason String?

  remarks String?

  status inspection_status @default(NOT_STARTED)
  progressPhoto Json?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project project @relation(fields: [projectId],references: [id])
  module inspection_module @relation(fields: [moduleId],references: [id])
  block project_block? @relation(fields: [blockId],references: [id])
  floor project_floor? @relation(fields: [floorId],references: [id])
  stage inspection_stage @relation(fields: [stageId],references: [id])

  answers inspection_answer[]

  @@unique([projectId,moduleId,blockId,floorId,roomNo,stageId])
}


model inspection_answer {

  id String @id @default(uuid())

  progressId String

  questionId String

  optionId String?

  answer String?

  progress inspection_progress @relation(fields: [progressId],references: [id])

  question inspection_question @relation(fields: [questionId],references: [id])

  option inspection_question_option? @relation(fields: [optionId],references: [id])

  images inspection_answer_image[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model inspection_answer_image {

  id String @id @default(uuid())

  answerId String

  imageUrl String

  answer inspection_answer @relation(fields: [answerId],references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum inspection_status {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}