generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id            String   @id @default(uuid()) @db.VarChar(36)

  username      String   @db.VarChar(255)

  email         String?   @unique @db.VarChar(255)

  passwordHash  String   @map("password_hash")

  roleId        String   @db.VarChar(36)

  role          role     @relation(fields: [roleId], references: [id])

  userManagements user_management[]

  createdProjects project[] @relation("ProjectCreatedBy")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  createdById   String?  @map("created_by") @db.VarChar(255)
  updatedById   String?  @map("updated_by") @db.VarChar(255)

  isActive      Boolean  @default(true) @map("is_active")

  @@map("users")
}


model user_management {
  id              String   @id @default(uuid()) @db.VarChar(36)

  userId          String   @db.VarChar(36)

  user            user@relation(fields: [userId], references: [id])

  departmentId    String   @db.VarChar(36)

  department      department@relation(fields: [departmentId], references: [id])

  districtId      String?  @db.VarChar(36)

  district        masterDistrict?@relation(fields: [districtId], references: [id])

  specialUnitId   String?  @db.VarChar(36)
  access_type   String   @default("SPECIFIC") @db.VarChar(50)

district_type String?  @db.VarChar(50)

  specialUnit     specialUnits?@relation(fields: [specialUnitId], references: [id])

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdById     String?  @map("created_by") @db.VarChar(255)
  updatedById     String?  @map("updated_by") @db.VarChar(255)

  isActive        Boolean  @default(true) @map("is_active")

  @@map("user_managements")
}
model role {
  id          String   @id @default(uuid()) @db.VarChar(36)

  name        String   @unique @db.VarChar(255)

  users       user[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)

  isActive    Boolean  @default(true) @map("is_active")

  @@map("roles")
}

model District {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        Int       @unique @map("code")
  name        String    @map("name") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String?   @map("created_by") @db.VarChar(255)
  updatedById String?   @map("updated_by") @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  

  @@index([code])
  @@map("districts")
}

model specialUnits {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @default(autoincrement()) @map("code")
  name        String   @map("name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

    userManagements user_management[]

  projectAccessMappings project_access_mapping[]

 


  @@index([code])
  @@map("special_units")
}

model LandSiteInspection {
  id        String @id @default(uuid())
  projectId String

  // 🔹 Encroachment
  isEncroachment      YesNo
  encroachmentPercent Float?
  encroachmentType    String?
  personEncroachingName String?
  encroachmentPhotos  Json? 

  isCourtCase         YesNo
  caseDetails         String?

  // 🔹 Existing Structure
  hasStructure     YesNo
  structureDetails String?
  structurePhotos  Json?

  // 🔹 Drainage
  isLowLying        YesNo
  waterDepth        Float?
  waterDurationDays Int?
  drainagePhotos    Json?

  // 🔹 Trees
  treesCount Int?
  treesPhoto Json?

  // 🔹 Power Lines
  hasPowerLines    YesNo
  powerLineDetails String?
  powerLinePhotos  Json?

  // 🔹 Restricted Zones
  isNearMonument   YesNo
  monumentName     String?
  monumentDistance Float?
  monumentPhotos   Json?

  isNearSea   YesNo
  seaDistance Float?
  seaPhotos   Json?

  isNearForest   YesNo
  forestName     String?
  forestDistance Float?
  forestPhotos   Json?

  isNearWaterBody   Boolean?
  waterBodyName     String?
  waterBodyDistance Float?
  waterBodyPhotos   Json?

  // 🔹 Burial Ground
  isNearBurial   YesNo
  burialName     String?
  burialDistance Float?
  burialPhotos   Json?

  // 🔹 Roads
  roadType  String?
  roadWidth Float?

  // 🔹 Essential Services
  nearestService  String?
  serviceDistance Float?

  // 🔹 Common
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

  project project @relation(fields: [projectId], references: [id])
}

enum DistrictType {
  DISTRICT
  CITY
}

enum BuildingType {
  OFFICE
  RESIDENCY
  OTHERS
}

enum JurisdictionType {
  DISTRICT
  CITY
  SPECIAL_UNIT
}

enum AccessType {
  SPECIFIC
  FULL_JURISDICTION
}

model project {
  id                    String   @id @default(uuid()) @db.VarChar(36)

  code                  Int      @unique @default(autoincrement())

  projectName           String   @db.VarChar(255)

  buildingType          BuildingType

  departmentId          String   @db.VarChar(36)

  department            department@relation(fields: [departmentId], references: [id])

  jurisdictionType      JurisdictionType

  accessType            AccessType

  location              String?  @db.Text

  hasSuperStructure     Boolean  @default(false)

  selectedStages        Json?

  createdByUserId       String   @db.VarChar(36)

  createdByUser         user@relation("ProjectCreatedBy",fields: [createdByUserId],references: [id])

  projectAccessMappings project_access_mapping[]

  blocks project_block[]
  floors project_floor[]

  projectHistories      project_history[]

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  createdById           String?  @map("created_by") @db.VarChar(255)
  updatedById           String?  @map("updated_by") @db.VarChar(255)

  isActive              Boolean  @default(true) @map("is_active")

  @@map("projects")


  status status @default(AssignedProjects) //  default here

  

  landSiteInspection         LandSiteInspection[]
  preConstructionInspections PreConstructionInspection[]
  foundationProgresses       FoundationProgress[]
  foundationQualityChecks    FoundationQualityCheck[]
  plinthStages               PlinthStage[]
  interiorsProgress interiorsProgress[]

  exteriorsProgress exteriorsProgress[]

  BuildingInspection         BuildingInspection[]
  DevelopmentWork            DevelopmentWork[]
  TakeoverBuildingInsepction TakeoverBuildingInspection[]
  TakeoverDevelopmentWork    TakeoverDevelopmentWork[]

  
    SuperStructureProgress superStructureProgress[]

  
 
}


model project_access_mapping {
  id              String   @id @default(uuid()) @db.VarChar(36)

  projectId       String   @db.VarChar(36)

  project         project@relation(fields: [projectId], references: [id])

  districtId      String?  @db.VarChar(36)

  district        masterDistrict?@relation(fields: [districtId], references: [id])

  specialUnitId   String?  @db.VarChar(36)

  specialUnit     specialUnits? @relation(fields: [specialUnitId], references: [id])

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdById     String?  @map("created_by") @db.VarChar(255)
  updatedById     String?  @map("updated_by") @db.VarChar(255)

  isActive        Boolean  @default(true) @map("is_active")

  @@map("project_access_mappings")
}  
model officer {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @default(autoincrement()) @map("code")
  name        String   @map("name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

  
}

model department {
  id          String   @id @default(uuid()) @db.VarChar(36)

  code        Int      @unique @default(autoincrement())

  name        String   @unique @db.VarChar(255)

  projects    project[]

  userManagements user_management[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)

  isActive    Boolean  @default(true) @map("is_active")

  @@map("departments")
}

model masterDistrict {
  id          String   @id @default(uuid()) @db.VarChar(36)

  code        Int      @unique @default(autoincrement())

  name        String   @db.VarChar(255)

  type        DistrictType

  userManagements user_management[]

  projectAccessMappings project_access_mapping[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)

  isActive    Boolean  @default(true) @map("is_active")

  @@unique([name, type])

  @@index([type])

  @@map("master_districts")
}

model AuditLog {
  id   String @id @default(uuid()) @db.VarChar(36)
  code Int    @unique @default(autoincrement())

  tableName String @map("table_name") @db.VarChar(100)
  recordId  String @map("record_id") @db.VarChar(36)

  action String @db.VarChar(20) // CREATE | UPDATE | DELETE

  oldValue Json? @map("old_value")
  newValue Json? @map("new_value")

  userId    String? @map("user_id") @db.VarChar(36)
  roleId    String? @map("role_id") @db.VarChar(36)
  ipAddress String? @map("ip_address") @db.VarChar(45)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id") @db.VarChar(36)
  updatedById String?  @map("updated_by_id") @db.VarChar(36)
  isActive    Boolean  @default(true) @map("is_active")

  @@index([tableName])
  @@index([recordId])
  @@map("audit_logs")
}

model stage {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        Int       @default(autoincrement()) @map("code")
  name        String    @map("name") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String?   @map("created_by") @db.VarChar(255)
  updatedById String?   @map("updated_by") @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
 

  @@map("stages")
}

model material {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())

  name        String   @unique @map("material_name") @db.VarChar(255)

  hasGrade    Boolean  @default(false) @map("has_grade")
  hasType     Boolean  @default(false) @map("has_type")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  isActive    Boolean  @default(true) @map("is_active")

  materialGrades      material_grade[]
  materialBrandGrades material_brand_grade[]

  @@index([code])
}

model brand {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())

  name        String   @unique @map("brand_name") @db.VarChar(255)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  isActive    Boolean  @default(true) @map("is_active")

  materialBrandGrades material_brand_grade[]

  @@index([code])
}

model grade {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())

  name        String   @unique @map("grade_name") @db.VarChar(255)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  isActive    Boolean  @default(true) @map("is_active")

  materialGrades      material_grade[]
  materialBrandGrades material_brand_grade[]

  @@index([code])
}
model material_type {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())

  name        String   @unique @db.VarChar(255)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  isActive    Boolean  @default(true) @map("is_active")

  materialGrades material_grade[]
  materialBrandGrades material_brand_grade[]

  @@index([code])
}

model material_grade {
  id              String          @id @default(uuid()) @db.VarChar(36)

  materialId      String          @map("material_id")

  gradeId         String?         @map("grade_id")

  materialTypeId  String?         @map("material_type_id")

  material        material        @relation(fields: [materialId], references: [id])

  grade           grade?          @relation(fields: [gradeId], references: [id])

  materialType    material_type?  @relation(fields: [materialTypeId], references: [id])

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  createdById     String?         @map("created_by")
  updatedById     String?         @map("updated_by")

  isActive        Boolean         @default(true) @map("is_active")

  @@unique([materialId, gradeId, materialTypeId])

  @@index([materialId])
  @@index([gradeId])
  @@index([materialTypeId])
}

model material_brand_grade {
  id              String   @id @default(uuid()) @db.VarChar(36)

  materialId      String   @map("material_id")

  brandId         String   @map("brand_id")

  gradeId         String?  @map("grade_id")

  typeId          String?  @map("type_id")

  material        material @relation(fields: [materialId], references: [id])

  brand           brand    @relation(fields: [brandId], references: [id])

  grade           grade?   @relation(fields: [gradeId], references: [id])

  type            material_type? @relation(fields: [typeId], references: [id])

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdById     String?  @map("created_by")
  updatedById     String?  @map("updated_by")

  isActive        Boolean  @default(true) @map("is_active")

  @@unique([materialId, brandId, gradeId])

  @@index([materialId])
  @@index([brandId])
  @@index([gradeId])
  @@index([typeId])
}
enum status {
  TotalProjects
  CompletedProjects
  OngoingProjects
  AssignedProjects
}

enum YesNo {
  Yes
  No
}



model PreConstructionInspection {
  id        String @id @default(uuid())
  projectId String

  //  Permissions
  isPermissionObtained YesNo
  permissionDate       DateTime?

  //  Site Clearance
  isSiteCleared YesNo
  siteDetails   String?

  //  Labour Shed
  hasLabourShed  YesNo
  labourShedType String?
  labourShedArea Float?

  hasWaterSupply    YesNo
  waterSupplyPhotos Json?

  hasToiletFacility YesNo
  toiletPhotos      Json?

  hasElectricity    YesNo
  electricityPhotos Json?

  //  Labour Registration
  labourCount  Int?
  labourPhotos Json?

  //  Material Storage
  hasMaterialStorage YesNo
  materialType       String?
  materialPhotos     Json?

  //  Electricity & Water
  hasTempElectricity YesNo
  waterType          String?

  // Access Road
  isAccessRoadGood YesNo
  accessRoadPhotos Json?

  //  Remarks
  remarks String?

  //  Common
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  isActive    Boolean  @default(true)

  project project @relation(fields: [projectId], references: [id])
}

model FoundationProgress {
  id        String @id @default(uuid())
  projectId String

  type FoundationType // Footing | Pile | Raft

  // COMMON
  total     Int?
  completed Int?
  photos    Json?

  workStartedDate DateTime?

  isDelay     Boolean @default(false)
  delayDays   Int?
  delayPhotos Json?

  delayReason      String?
  delayOtherReason String?

  generalRemarks String?

  // ONLY FOR RAFT
  raftType String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")
  isActive    Boolean  @default(true) @map("is_active")

  project project @relation(fields: [projectId], references: [id])
}

enum FoundationType {
  Footing
  Pile
  Raft
}

model FoundationQualityCheck {
  id        String @id @default(uuid())
  projectId String

  cementGradeId String?
  cementBrandId String?
  cementRemarks String?

  cementLabTest String? // dropdown value
  cementPhoto   Json?

  sandType String? // "RIVER" | "M_SAND" (from UI)

  sandLabTest String?
  sandPhoto   Json?

  sandSieveTestDone Boolean?

  sandSieveLabTest String?
  sandSievePhoto   Json?

  steelGradeId String?
  steelBrandId String?

  steelLabTest String?
  steelPhoto   Json?

  aggregateSize Float?

  aggregateLabTest String?
  aggregatePhoto   Json?

  waterLabTest String?
  waterPhoto   Json?

  concreteLabTest String?
  concretePhoto   Json?

  concreteQualityTestDone Boolean?

  concreteQualityLabTest String?
  concreteQualityPhoto   Json?

  bricksLabTest String?
  bricksPhoto   Json?

  bricksQualityTestDone Boolean?

  bricksQualityLabTest String?
  bricksQualityPhoto   Json?

  remarks String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")
  isActive    Boolean  @default(true) @map("is_active")

  project project @relation(fields: [projectId], references: [id])
}

model PlinthStage {
  id        String @id @default(uuid())
  projectId String

  stageOfWork String? // Plinth Beam / Brick Work / Earth Filling / Floor Concreting

  isCompleted     Boolean? // YES = true / NO = false
  progressRemarks String?
  progressPhoto   Json?

  workStartedDate DateTime?

  isDelay   Boolean?
  delayDays Int?

  delayReason      String?
  delayOtherReason String?

  // CEMENT
  cementGradeId String?
  cementBrandId String?
  cementRemarks String?

  cementLabTest String?
  cementPhoto   Json?

  // SAND
  sandType String?

  sandLabTest String?
  sandPhoto   Json?

  sandSieveTestDone Boolean?

  sandSieveLabTest String?
  sandSievePhoto   Json?

  // STEEL
  steelGradeId String?
  steelBrandId String?

  steelLabTest String?
  steelPhoto   Json?

  // AGGREGATES
  aggregateSize Float?

  aggregateLabTest String?
  aggregatePhoto   Json?

  // WATER
  waterLabTest String?
  waterPhoto   Json?

  // CONCRETE
  concreteLabTest String?
  concretePhoto   Json?

  concreteQualityTestDone Boolean?

  concreteQualityLabTest String?
  concreteQualityPhoto   Json?

  // BRICKS
  bricksLabTest String?
  bricksPhoto   Json?

  bricksQualityTestDone Boolean?

  bricksQualityLabTest String?
  bricksQualityPhoto   Json?

  qualityRemarks String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")
  isActive    Boolean  @default(true) @map("is_active")

  project project @relation(fields: [projectId], references: [id])
}

model interiorsProgress {
id String @id @default(uuid())
 projectId String 
 blockId String 
 floorId String 
 stage String? 

 

  progressPhoto Json?
  progressRemarks String?
  project project @relation(fields: [projectId], references: [id]) 
  block project_block @relation(fields: [blockId], references: [id])
   floor project_floor @relation(fields: [floorId], references: [id]) 
  
quality interiorsQuality?
