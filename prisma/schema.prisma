  tileBrand String?
  tileRemarks String?

  // PAINTING
  paintBrand String?
  paintingQuality String?

  qualityRemarks String?
   isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum interiorsStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model exteriorsProgress {
 id String @id @default(uuid()) 
 projectId String 
 blockId String
  floorId String 
  stage String? 
  
remarks String?
 status exteriorsStatus @default(NOT_STARTED)

  

  progressPhoto Json?
  
project project @relation(fields: [projectId], references: [id])
 block project_block @relation(fields: [blockId], references: [id]) 
 floor project_floor @relation(fields: [floorId], references: [id]) 
 quality exteriorsQuality?
  
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model exteriorsQuality {
 id String @id @default(uuid())
  progressId String @unique 
  progress exteriorsProgress @relation(fields: [progressId], references: [id])

  workStartedDate DateTime?

  isDelayed Boolean?

  delayDays Int?
  delayReason String?
  delayOther String?

  generalRemarks String?

  // CEMENT
  cementGradeId String?
  cementBrandId String?
  cementRemarks String?
  cementLabTest String?
  cementPhoto Json?

  // SAND
  sandType String?
  sandLabTest String?
  sandPhoto Json?

  sandSieveTestDone Boolean?
  sandSieveLabTest String?
  sandSievePhoto Json?

  // AGGREGATE
  aggregateSize Float?
  aggregateLabTest String?
  aggregatePhoto Json?

  // WATER
  waterLabTest String?
  waterPhoto Json?

  // CONCRETE
  concreteLabTest String?
  concretePhoto Json?

  concreteQualityTestDone Boolean?
  concreteQualityLabTest String?
  concreteQualityPhoto Json?

  // BRICKS
  bricksLabTest String?
  bricksPhoto Json?

  bricksQualityTestDone Boolean?
  bricksQualityLabTest String?
  bricksQualityPhoto Json?

